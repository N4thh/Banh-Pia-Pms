datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ShippingMethod {
  DELIVERY
  PICKUP
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
}

enum OrderStatus {
  NEW
  PROCESSING
  COMPLETED
  CANCELLED
}

enum PaymentLinkStatus {
  PENDING
  PAID
  CANCELLED
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  fullName     String
  updatedAt    DateTime @updatedAt
}

model User {
  id        Int       @id @default(autoincrement())
  phone     String    @unique
  fullName  String?
  addresses Address[]
  orders    Order[]
  createdAt DateTime  @default(now())
}

model Address {
  id          Int      @id @default(autoincrement())
  houseNumber String
  street      String
  ward        String
  district    String
  city        String   @default("Hồ Chí Minh")

  userId Int
  user   User @relation(fields: [userId], references: [id])

  orders Order[]
}

model Cake {
  id           Int            @id @default(autoincrement())
  kind         String         @unique
  description  String?
  basePrice    Decimal
  availability Availability[]
  orderItems   OrderItem[]
}

model Availability {
  id            Int      @id @default(autoincrement())
  cakeId        Int
  cake          Cake     @relation(fields: [cakeId], references: [id])
  date          DateTime @db.Date
  maxCapacity   Int      @default(50)
  bufferLimit   Int      @default(2)
  currentBooked Int      @default(0)

  @@unique([cakeId, date])
}

model Order {
  id             Int             @id @default(autoincrement())
  userId         Int
  user           User            @relation(fields: [userId], references: [id])

  addressId Int?
  address   Address? @relation(fields: [addressId], references: [id])

  totalMoney     Decimal
  note           String?
  orderDate      DateTime       @default(now())
  receiveDate    DateTime
  shippingMethod ShippingMethod
  paymentMethod  PaymentMethod
  status         OrderStatus    @default(NEW)

  items OrderItem[]

  paymentLink PaymentLink?
}

model OrderItem {
  id      Int   @id @default(autoincrement())
  orderId Int
  order   Order @relation(fields: [orderId], references: [id])

  cakeId Int
  cake   Cake @relation(fields: [cakeId], references: [id])

  eggCount        Int     @default(0)
  quantity        Int
  priceAtPurchase Decimal
}

model PaymentLink {
  id      String @id

  orderId Int   @unique
  order   Order @relation(fields: [orderId], references: [id])

  checkoutUrl String
  qrCode      String

  status PaymentLinkStatus @default(PENDING)

  amountPaid      Decimal @default(0)
  amountRemaining Decimal

  cancellationReason String?
  canceledAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions PaymentTransaction[]
}

model PaymentTransaction {
  id            Int         @id @default(autoincrement())
  paymentLinkId String
  paymentLink   PaymentLink @relation(fields: [paymentLinkId], references: [id])

  reference           String   @unique
  amount              Decimal
  transactionDateTime DateTime
  description         String

  counterAccountNumber String?
  counterAccountName   String?
  counterAccountBank   String?

  signatureValid Boolean
  rawPayload     Json

  createdAt DateTime @default(now())
}